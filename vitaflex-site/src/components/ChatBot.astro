---
const suggestions = [
  'Por que usar Light Agent?',
  'Como funciona o agente FastAPI + Agno?',
  'Quais métricas da Parte 4?',
  'Resuma a simulação da Parte 6',
];
---

<div id="chat-widget" class="no-print fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">
  <div
    id="chat-panel"
    class="hidden w-[min(100vw-2rem,400px)] flex-col overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-[0_8px_40px_rgba(26,95,255,0.15)]"
    role="dialog"
    aria-label="Assistente do desafio"
  >
    <div class="flex items-center gap-3 px-4 py-3.5 text-white chat-header-gradient">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white/20 text-lg" aria-hidden="true">
        💬
      </div>
      <div class="min-w-0 flex-1">
        <p class="truncate text-sm font-semibold">Assistente do Desafio</p>
        <p class="text-xs uppercase tracking-wide text-blue-100">eteg · Zendesk VitaFlex</p>
      </div>
      <button
        id="chat-clear"
        type="button"
        class="rounded-lg px-2 py-1 text-xs text-blue-100 hover:bg-white/15"
        title="Nova conversa"
      >
        Limpar
      </button>
      <button id="chat-close" type="button" class="rounded-lg p-1.5 hover:bg-white/20" aria-label="Fechar">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="chat-context" class="hidden border-b px-4 py-2 text-xs chat-context-bar">
      Contexto: <span id="chat-context-label" class="font-medium"></span>
    </div>

    <div id="chat-messages" class="flex max-h-[min(60vh,420px)] flex-col gap-3 overflow-y-auto p-4 text-sm">
      <div class="chat-bubble-assistant mr-6 rounded-2xl rounded-bl-md border border-slate-100 bg-slate-50 px-3.5 py-2.5 text-slate-700 shadow-sm">
        <p class="font-medium text-slate-800">Olá! Sou o assistente desta apresentação.</p>
        <p class="mt-1.5 text-slate-600">
          Posso explicar decisões, racional e detalhes das Partes 1–6, do Anexo (JSONs) e do documento de racional.
        </p>
      </div>
    </div>

    <div id="chat-suggestions" class="flex flex-wrap gap-2 border-t border-slate-100 px-4 py-3">
      {suggestions.map((q) => (
        <button
          type="button"
          class="chat-suggestion rounded-full border px-3 py-1.5 text-left text-xs transition chat-suggestion-chip"
          data-question={q}
        >
          {q}
        </button>
      ))}
    </div>

    <form id="chat-form" class="flex items-end gap-2 border-t border-slate-200 bg-slate-50/80 p-3">
      <input
        id="chat-input"
        type="text"
        placeholder="Pergunte sobre o desafio..."
        class="flex-1 rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm outline-none transition chat-input"
        autocomplete="off"
        maxlength="500"
      />
      <button
        id="chat-send"
        type="submit"
        class="chat-btn-primary flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-white transition disabled:cursor-not-allowed disabled:opacity-50"
        aria-label="Enviar"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
        </svg>
      </button>
    </form>
  </div>

  <button
    id="chat-toggle"
    type="button"
    class="chat-btn-primary group relative flex h-14 w-14 items-center justify-center rounded-full text-white shadow-lg transition hover:scale-105"
    aria-label="Abrir assistente"
    aria-expanded="false"
  >
    <span id="chat-badge" class="absolute -right-0.5 -top-0.5 hidden h-3 w-3 rounded-full bg-emerald-400 ring-2 ring-white"></span>
    <svg id="chat-icon-open" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
    </svg>
    <svg id="chat-icon-close" class="hidden h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
</div>

<style>
  .chat-header-gradient {
    background: linear-gradient(90deg, #1a5fff 0%, #0047cc 100%);
  }

  .chat-context-bar {
    border-color: #e8f0ff;
    background-color: rgb(232 240 255 / 0.6);
    color: #0047cc;
  }

  .chat-suggestion-chip {
    border-color: rgb(26 95 255 / 0.25);
    background-color: rgb(232 240 255 / 0.5);
    color: #0047cc;
  }

  .chat-suggestion-chip:hover {
    border-color: #1a5fff;
    background-color: #e8f0ff;
  }

  .chat-input:focus {
    border-color: #1a5fff;
    box-shadow: 0 0 0 2px rgb(26 95 255 / 0.2);
    outline: none;
  }

  .chat-btn-primary {
    background-color: #1a5fff;
    box-shadow: 0 4px 14px rgb(26 95 255 / 0.35);
  }

  .chat-btn-primary:hover:not(:disabled) {
    background-color: #0047cc;
  }

  :global(.chat-bubble-user) {
    background-color: #1a5fff;
    color: #ffffff;
  }

  :global(.chat-bubble-assistant) {
    color: #334155;
  }

  :global(.chat-bubble-assistant strong) {
    font-weight: 600;
    color: #0f172a;
  }

  :global(.chat-bubble-assistant ul) {
    margin: 0.5rem 0;
    list-style-type: disc;
    padding-left: 1rem;
  }

  :global(.chat-bubble-assistant li + li) {
    margin-top: 0.25rem;
  }

  :global(.chat-bubble-assistant p + p) {
    margin-top: 0.5rem;
  }

  :global(.chat-typing) {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-right: 1.5rem;
    border-radius: 1rem;
    border-bottom-left-radius: 0.375rem;
    border: 1px solid #f1f5f9;
    background-color: #f8fafc;
    padding: 0.75rem 1rem;
  }

  :global(.chat-typing span) {
    display: inline-block;
    height: 0.5rem;
    width: 0.5rem;
    border-radius: 9999px;
    background-color: #5a7d9a;
    animation: chat-bounce 1.2s infinite ease-in-out;
  }

  :global(.chat-typing span:nth-child(2)) {
    animation-delay: 0.15s;
  }

  :global(.chat-typing span:nth-child(3)) {
    animation-delay: 0.3s;
  }

  @keyframes chat-bounce {
    0%,
    80%,
    100% {
      transform: translateY(0);
      opacity: 0.4;
    }
    40% {
      transform: translateY(-4px);
      opacity: 1;
    }
  }
</style>

<script>
  const panel = document.getElementById('chat-panel');
  const toggle = document.getElementById('chat-toggle');
  const closeBtn = document.getElementById('chat-close');
  const clearBtn = document.getElementById('chat-clear');
  const form = document.getElementById('chat-form') as HTMLFormElement;
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
  const messages = document.getElementById('chat-messages');
  const suggestionsEl = document.getElementById('chat-suggestions');
  const contextBar = document.getElementById('chat-context');
  const contextLabel = document.getElementById('chat-context-label');
  const iconOpen = document.getElementById('chat-icon-open');
  const iconClose = document.getElementById('chat-icon-close');
  const badge = document.getElementById('chat-badge');

  const history: { role: string; content: string }[] = [];
  let isOpen = false;
  let isLoading = false;

  const pageLabels: Record<string, string> = {
    '/': 'Parte 1 — Fluxos e Acessos',
    '/parte-1': 'Parte 1 — Fluxos e Acessos',
    '/parte-2': 'Parte 2 — Omnichannel e IA',
    '/parte-3': 'Parte 3 — Base de Conhecimento',
    '/parte-4': 'Parte 4 — Métricas e Governança',
    '/parte-5': 'Parte 5 — Diagnóstico Técnico',
    '/parte-6': 'Parte 6 — Simulação Ponta a Ponta',
    '/anexo': 'Anexo — JSONs',
    '/racional': 'Racional das Decisões',
  };

  function getPageContext() {
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    return { path, label: pageLabels[path] ?? 'Apresentação geral' };
  }

  function updateContextBar() {
    const { label } = getPageContext();
    if (contextLabel) contextLabel.textContent = label;
    contextBar?.classList.remove('hidden');
  }

  function escapeHtml(text: string) {
    return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function formatReply(text: string) {
    const trimmed = text.trim();
    if (!trimmed) return '<p>Sem resposta.</p>';

    const lines = trimmed.split('\n');
    const parts: string[] = [];
    let inList = false;

    for (const line of lines) {
      const lineTrim = line.trim();
      if (!lineTrim) {
        if (inList) {
          parts.push('</ul>');
          inList = false;
        }
        continue;
      }

      const content = escapeHtml(lineTrim).replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');

      if (/^[-•] /.test(lineTrim)) {
        if (!inList) {
          parts.push('<ul>');
          inList = true;
        }
        parts.push(`<li>${content.replace(/^[-•] /, '')}</li>`);
      } else {
        if (inList) {
          parts.push('</ul>');
          inList = false;
        }
        parts.push(`<p>${content}</p>`);
      }
    }

    if (inList) parts.push('</ul>');
    return parts.join('') || `<p>${escapeHtml(trimmed)}</p>`;
  }

  function addMsg(text: string, role: 'user' | 'assistant' | 'error') {
    const content = text.trim();
    if (!content) return;

    const div = document.createElement('div');
    if (role === 'user') {
      div.className =
        'chat-bubble-user ml-10 rounded-2xl rounded-br-md px-3.5 py-2.5 shadow-sm';
      div.textContent = content;
    } else if (role === 'error') {
      div.className =
        'mr-6 rounded-2xl border border-red-200 bg-red-50 px-3.5 py-2.5 text-red-700';
      div.textContent = content;
    } else {
      div.className =
        'chat-bubble-assistant mr-6 rounded-2xl rounded-bl-md border border-slate-100 bg-slate-50 px-3.5 py-2.5 shadow-sm';
      div.innerHTML = formatReply(content);
    }
    messages?.appendChild(div);
    messages?.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
  }

  function showTyping() {
    const div = document.createElement('div');
    div.id = 'chat-typing';
    div.className = 'chat-typing';
    div.innerHTML = '<span></span><span></span><span></span>';
    messages?.appendChild(div);
    messages?.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
  }

  function hideTyping() {
    document.getElementById('chat-typing')?.remove();
  }

  function hideSuggestions() {
    suggestionsEl?.classList.add('hidden');
  }

  function setOpen(open: boolean) {
    isOpen = open;
    panel?.classList.toggle('hidden', !open);
    panel?.classList.toggle('flex', open);
    toggle?.setAttribute('aria-expanded', String(open));
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
    badge?.classList.add('hidden');
    if (open) {
      updateContextBar();
      input?.focus();
    }
  }

  function resetChat() {
    history.length = 0;
    if (!messages) return;
    messages.innerHTML = `
      <div class="chat-bubble-assistant mr-6 rounded-2xl rounded-bl-md border border-slate-100 bg-slate-50 px-3.5 py-2.5 text-slate-700 shadow-sm">
        <p class="font-medium text-slate-800">Conversa reiniciada.</p>
        <p class="mt-1.5 text-slate-600">Pergunte o que quiser sobre o desafio Zendesk — VitaFlex.</p>
      </div>`;
    suggestionsEl?.classList.remove('hidden');
  }

  async function sendMessage(msg: string) {
    if (!msg || isLoading) return;

    hideSuggestions();
    addMsg(msg, 'user');
    input.value = '';
    isLoading = true;
    input.disabled = true;
    sendBtn.disabled = true;
    showTyping();

    const { path, label } = getPageContext();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg, history, page: path, pageLabel: label }),
      });
      const data = await res.json();
      hideTyping();

      if (!res.ok) {
        addMsg(data.error || 'Erro ao consultar assistente.', 'error');
        return;
      }

      addMsg(data.reply, 'assistant');
      history.push({ role: 'user', content: msg });
      history.push({ role: 'assistant', content: data.reply });
    } catch {
      hideTyping();
      addMsg('Falha de conexão. Verifique se o servidor está rodando.', 'error');
    } finally {
      isLoading = false;
      input.disabled = false;
      sendBtn.disabled = false;
      input.focus();
    }
  }

  toggle?.addEventListener('click', () => setOpen(!isOpen));
  closeBtn?.addEventListener('click', () => setOpen(false));
  clearBtn?.addEventListener('click', resetChat);

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    sendMessage(input.value.trim());
  });

  suggestionsEl?.querySelectorAll('.chat-suggestion').forEach((btn) => {
    btn.addEventListener('click', () => {
      const q = (btn as HTMLButtonElement).dataset.question;
      if (q) sendMessage(q);
    });
  });

  badge?.classList.remove('hidden');
</script>
