---
interface Props {
  part: string;
  title: string;
  description: string;
}

const { part, title, description } = Astro.props;
---

<div class="relative overflow-hidden border-b border-slate-800 bg-gradient-to-b from-zendesk-dark/20 to-transparent">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-zendesk-light/10 via-transparent to-transparent" />
  <div class="relative mx-auto max-w-7xl section-padding !pb-12">
    <p class="mb-3 inline-flex items-center gap-2 rounded-full border border-zendesk-light/30 bg-zendesk-dark/40 px-4 py-1 text-sm font-medium text-zendesk-light">
      {part}
    </p>
    <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">{title}</h1>
    <p class="mt-4 max-w-3xl text-lg text-slate-400">{description}</p>
  </div>
</div>
