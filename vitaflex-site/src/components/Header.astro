---
import { partes } from '../utils/docs';
import etegLogo from '../assets/eteg-logo.png';

const currentPath = Astro.url.pathname;
---

<header class="no-print sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-3">
      <img src={etegLogo.src} alt="eteg technology" class="h-8 w-auto" />
      <span class="hidden text-sm text-eteg-muted sm:inline">Desafio Técnico Zendesk</span>
    </a>

    <nav class="flex items-center gap-1 overflow-x-auto text-sm">
      {partes.map((p) => (
        <a
          href={p.id === 1 ? '/' : `/${p.slug}`}
          class:list={[
            'rounded px-2.5 py-1.5 whitespace-nowrap transition',
            (p.id === 1 && (currentPath === '/' || currentPath === '/parte-1')) ||
              currentPath === `/${p.slug}`
              ? 'bg-eteg-light font-semibold text-eteg'
              : 'text-slate-600 hover:text-eteg',
          ]}
        >
          {p.id}
        </a>
      ))}
      <a
        href="/anexo"
        class:list={[
          'rounded px-2.5 py-1.5 whitespace-nowrap transition',
          currentPath === '/anexo' ? 'bg-eteg-light font-semibold text-eteg' : 'text-slate-600 hover:text-eteg',
        ]}
      >
        Anexo
      </a>
      <a
        href="/racional"
        class:list={[
          'rounded px-2.5 py-1.5 whitespace-nowrap transition',
          currentPath === '/racional' ? 'bg-eteg-light font-semibold text-eteg' : 'text-slate-600 hover:text-eteg',
        ]}
      >
        Racional
      </a>
    </nav>
  </div>
</header>
