---
import { partes } from '../utils/docs';
import etegLogo from '../assets/eteg-logo.png';
import PdfButton from './PdfButton.astro';

const currentPath = Astro.url.pathname;
---

<header class="no-print sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex h-[4.25rem] max-w-7xl items-center gap-4 px-4 sm:px-6">
    <a href="/" class="flex min-w-0 shrink-0 items-center gap-3 sm:gap-4">
      <img src={etegLogo.src} alt="eteg technology" class="h-9 w-auto shrink-0" />
      <div class="hidden min-w-0 border-l border-slate-200 pl-4 sm:block">
        <p class="truncate text-base font-bold leading-tight text-slate-900 sm:text-lg">
          Desafio Técnico Zendesk
        </p>
        <p class="truncate text-sm font-medium" style="color: #1a5fff;">Lucas Marcondes</p>
      </div>
    </a>

    <nav class="ml-auto flex items-center gap-1 overflow-x-auto text-sm">
      {partes.map((p) => {
        const active =
          (p.id === 1 && (currentPath === '/' || currentPath === '/parte-1')) ||
          currentPath === `/${p.slug}`;
        return (
          <a
            href={p.id === 1 ? '/' : `/${p.slug}`}
            class:list={[
              'rounded px-2.5 py-1.5 whitespace-nowrap transition',
              active
                ? 'bg-[#e8f0ff] font-semibold text-[#1a5fff]'
                : 'text-slate-600 hover:text-[#1a5fff]',
            ]}
          >
            {p.id}
          </a>
        );
      })}
      <a
        href="/anexo"
        class:list={[
          'rounded px-2.5 py-1.5 whitespace-nowrap transition',
          currentPath === '/anexo'
            ? 'bg-[#e8f0ff] font-semibold text-[#1a5fff]'
            : 'text-slate-600 hover:text-[#1a5fff]',
        ]}
      >
        Anexo
      </a>
      <a
        href="/racional"
        class:list={[
          'rounded px-2.5 py-1.5 whitespace-nowrap transition',
          currentPath === '/racional'
            ? 'bg-[#e8f0ff] font-semibold text-[#1a5fff]'
            : 'text-slate-600 hover:text-[#1a5fff]',
        ]}
      >
        Racional
      </a>
      <span class="mx-1 hidden h-5 w-px bg-slate-200 sm:inline" aria-hidden="true"></span>
      <PdfButton />
    </nav>
  </div>

  <div class="border-t border-slate-100 px-4 py-1.5 sm:hidden">
    <p class="text-center text-sm font-bold text-slate-900">Desafio Técnico Zendesk</p>
    <p class="text-center text-xs font-medium" style="color: #1a5fff;">Lucas Marcondes</p>
  </div>
</header>
