---
interface Props {
  headers: string[];
  rows: string[][];
}

const { headers, rows } = Astro.props;
---

<div class="prose-table">
  <table>
    <thead>
      <tr>
        {headers.map((h) => <th>{h}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          {row.map((cell) => <td set:html={cell} />)}
        </tr>
      ))}
    </tbody>
  </table>
</div>
