---
interface Props {
  time: string;
  title: string;
  desc: string;
  tags: string[];
  isLast?: boolean;
}

const { time, title, desc, tags, isLast = false } = Astro.props;
---

<div class="relative flex gap-6 pb-8">
  {!isLast && <div class="absolute left-[19px] top-10 h-full w-px bg-gradient-to-b from-zendesk-light/50 to-transparent" />}
  <div class="relative z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border-2 border-zendesk-light bg-slate-900">
    <div class="h-3 w-3 rounded-full bg-zendesk-light" />
  </div>
  <div class="flex-1 glass-card p-5">
    <div class="flex flex-wrap items-center gap-3">
      <span class="font-mono text-sm font-medium text-zendesk-light">{time}</span>
      <h4 class="font-semibold text-white">{title}</h4>
    </div>
    <p class="mt-2 text-sm text-slate-400">{desc}</p>
    <div class="mt-3 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-md bg-slate-800 px-2 py-0.5 font-mono text-xs text-slate-400">{tag}</span>
      ))}
    </div>
  </div>
</div>
